           diffuse="0.94 0.91 0.88" specular="0.45 0.45 0.45"
           intensity="0.95" bulbradius="0.22" cutoff="55"/>

    <geom name="floor" type="plane" pos="0 0 0" size="3 3 0.02" material="floor"/>
    <geom name="back_wall" type="box" pos="0 1.45 1.5" size="1.45 0.025 1.5" material="wall"/>
    <geom name="right_wall" type="box" pos="1.05 0.72 1.5" size="0.025 0.95 1.5" material="wall"/>
    <geom name="table_top" type="box" pos="0 0.78 0.765" size="0.50 0.56 0.015" material="table"/>
    <geom name="table_leg_00" type="box" pos="-0.45 0.26 0.375" size="0.018 0.018 0.375" material="dark"/>
    <geom name="table_leg_01" type="box" pos="-0.45 1.30 0.375" size="0.018 0.018 0.375" material="dark"/>
    <geom name="table_leg_10" type="box" pos="0.45 0.26 0.375" size="0.018 0.018 0.375" material="dark"/>
    <geom name="table_leg_11" type="box" pos="0.45 1.30 0.375" size="0.018 0.018 0.375" material="dark"/>
