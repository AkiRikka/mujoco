<mujoco model="nelif_table_arm_spin">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="512" offheight="512"/>
    <quality shadowsize="2048" offsamples="0"/>
    <headlight ambient="0 0 0" diffuse="0 0 0" specular="0 0 0"/>
    <map znear="0.01" zfar="20"/>
  </visual>

  <default>
    <joint damping="0.05"/>
  </default>

  <asset>
    <material name="floor" rgba="0.31 0.38 0.36 1" specular="0.10" shininess="0.25"/>
    <material name="wall" rgba="0.73 0.70 0.65 1" specular="0.10" shininess="0.25"/>
