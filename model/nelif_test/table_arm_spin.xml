    <geom name="blue_block" type="box" pos="0.27 0.98 0.82" size="0.045 0.04 0.035" material="blue" quat="0.966 0 0 -0.259"/>

    <body name="arm_base" pos="-0.06 0.72 0.83">
      <geom name="base" type="cylinder" size="0.07 0.025" material="dark"/>
      <body name="link1" pos="0 0 0.05">
        <joint name="shoulder" type="hinge" axis="0 0 1"/>
        <geom name="link1_geom" type="capsule" fromto="0 0 0 0.28 0 0.06" size="0.035" material="robot"/>
        <body name="link2" pos="0.28 0 0.06">
          <joint name="elbow" type="hinge" axis="0 0 1"/>
          <geom name="link2_geom" type="capsule" fromto="0 0 0 0.22 0 0.03" size="0.028" material="robot"/>
          <geom name="wrist" type="sphere" pos="0.24 0 0.03" size="0.035" material="dark"/>
        </body>
      </body>
    </body>
  </worldbody>

  <keyframe>
    <key name="spin" qpos="0 0.7" qvel="1.6 -1.1"/>
  </keyframe>
</mujoco>
